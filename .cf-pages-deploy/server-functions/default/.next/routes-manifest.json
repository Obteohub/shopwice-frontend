{
  "version": 3,
  "pages404": true,
  "appType": "hybrid",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/brand/von",
      "destination": "/brand/avon",
      "statusCode": 308,
      "regex": "^(?!/_next)/brand/von(?:/)?$"
    },
    {
      "source": "/brand/von/:path*",
      "destination": "/brand/avon/:path*",
      "statusCode": 308,
      "regex": "^(?!/_next)/brand/von(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/tag/:path*",
      "destination": "/collection/:path*",
      "statusCode": 308,
      "regex": "^(?!/_next)/tag(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/:all*(svg|jpg|jpeg|png|webp|avif|js|css|woff2)",
      "locale": false,
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(svg|jpg|jpeg|png|webp|avif|js|css|woff2)(?:/)?$"
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ],
      "regex": "^(?:/(.*))(?:/)?$"
    }
  ],
