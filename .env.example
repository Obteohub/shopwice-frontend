# WordPress backend base URL (no trailing slash)
NEXT_PUBLIC_WP_API_URL=https://shopwice.com
# Frontend domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yoursite.com
# Force all pages on this deployment to noindex/nofollow and emit a blocking robots.txt.
NEXT_PUBLIC_SITE_NOINDEX=false

# Default OG image fallback (absolute URL)
NEXT_PUBLIC_OG_DEFAULT_IMAGE=https://yoursite.com/images/og-default.jpg

# Site name used in fallback titles
NEXT_PUBLIC_SITE_NAME=Your Store Name
# RankMath getHead timeout in milliseconds (default: 8000)
RANKMATH_TIMEOUT_MS=8000

# Noindex thin archive pages with fewer than N products (default: 3)
SEO_THIN_ARCHIVE_THRESHOLD=3

# Enable/disable noindex for thin archives (default: true)
SEO_NOINDEX_THIN_ARCHIVES=true

NEXT_PUBLIC_REST_API_URL=https://api.shopwice.com/api
NEXT_PUBLIC_STORE_API_URL=https://api.shopwice.com/api
NEXT_PUBLIC_GTM_ID=
NODE_ENV=development
NEXT_PUBLIC_AUTH_TOKEN_SS_KEY=auth-token
NEXT_PUBLIC_REFRESH_TOKEN_LS_KEY=refresh-token
NEXT_PUBLIC_SESSION_TOKEN_LS_KEY=session-token
NEXT_PUBLIC_AUTH_KEY_TIMEOUT=300000

# Enable lightweight review -> product rating enrichment on listing APIs.
# Set to false only if your middleware already returns averageRating/reviewCount.
ENABLE_PRODUCT_REVIEW_ENRICH=true
# Number of review pages scanned per request when building rating cache (default: 1)
REVIEW_MAX_PAGE_SCANS_PER_REQUEST=1

# Collection debugging: logs exact /api/products query built from active filter state.
NEXT_PUBLIC_COLLECTION_DEBUG_QUERY=false
