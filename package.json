{
  "name": "shopwice",
  "version": "1.2.4",
  "private": true,
  "scripts": {
    "lhci": "lhci autorun",
    "lhci:perf": "lhci autorun --collect.settings.preset=perf",
    "lhci:desktop": "lhci autorun --collect.settings.preset=desktop",
    "dev": "next dev --turbopack",
    "analyze": "node scripts/analyze-build.mjs",
    "pages:build": "node scripts/pages-build.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "playwright": "npx playwright test",
    "playwright:ui": "npx playwright test --ui",
    "playwright:debug": "npx playwright test --debug",
    "playwright:codegen": "playwright codegen",
    "test:seo": "vitest run src/components/SeoHead.test.ts src/utils/parseSeoHead.test.ts src/utils/seo.test.ts src/utils/seoProductSchema.test.ts src/utils/seoPage.test.ts src/tests/seo/productCategorySeo.test.tsx src/tests/seo/productPageSeo.test.tsx",
    "refresh": "rm -rf node_modules && rm package-lock.json && npm i && npm run format",
    "generate-reviews": "node scripts/generate-reviews.js",
    "postbuild": "next-sitemap"
  },
  "keywords": [
    "next.js",
    "next",
    "javascript",
    "framer"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "@react-oauth/google": "^0.13.4",
    "@sentry/nextjs": "^10.42.0",
    "@types/react": "^19.2.7",
    "@types/react-facebook-login": "^4.1.11",
    "autoprefixer": "^10.4.23",
    "isomorphic-dompurify": "^2.35.0",
    "lodash": "^4.17.21",
    "motion": "^12.23.26",
    "next": "16.1.1",
    "next-seo": "^6.6.0",
    "next-sitemap": "^4.2.3",
    "node-fetch": "^3.3.2",
    "node-html-parser": "^7.1.0",
    "nprogress": "^0.2.0",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-facebook-login": "^4.1.1",
    "react-hook-form": "^7.69.0",
    "swr": "^2.4.1",
    "use-places-autocomplete": "^4.0.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@opennextjs/cloudflare": "^1.17.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/google.maps": "^3.58.1",
    "@types/lodash": "^4.17.21",
    "@types/node": "24.10.4",
    "@types/nprogress": "^0.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-plugin-styled-components": "^2.1.4",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "postcss-preset-env": "^10.5.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.63.0"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ]
}
